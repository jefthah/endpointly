generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgres"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  username  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
